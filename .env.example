# Webflow Cloud CLI auth creates these in a root .env file.
# Keep this separate from .env.local, which is for local Next.js development.
WEBFLOW_SITE_ID=your-webflow-site-id
WEBFLOW_API_TOKEN=your-webflow-api-token

# Webflow Cloud injects these when the app is mounted under a product path.
BASE_URL=
ASSETS_PREFIX=
