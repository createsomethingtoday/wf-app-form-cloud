{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "webflow-app-form",
  "main": "custom-worker.ts",
  "compatibility_date": "2026-03-17",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "SUBMISSIONS_DB",
      "database_name": "wf-bl-app-form-cloud",
      "database_id": "dff8622b-864e-4475-a4b7-29216881ea9b",
      "migrations_dir": "./scripts/migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "FORM_UPLOADS",
      "bucket_name": "webflow-app-form-uploads"
    }
  ]
}
