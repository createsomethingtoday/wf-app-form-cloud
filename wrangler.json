    }
  ],
  "r2_buckets": [
    {
      "binding": "FORM_UPLOADS",
      "bucket_name": "wf-bl-app-form-cloud-uploads"
    }
  ],
  "vars": {
    "FORM_UPLOADS_PUBLIC_URL": "https://pub-d834297323f546c6acd399145c2ee05e.r2.dev"
  },
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "triggers": {
