# Copy this to .env.local and fill in your values

# Webhook configuration
WEBHOOK_URL=https://hooks.airtable.com/workflows/v1/genericWebhook/your-app-id/your-webhook-id/your-trigger-id
WEBHOOK_TOKEN=your-webhook-authentication-token

# Admin API protection for internal submission endpoints
ADMIN_API_TOKEN=your-long-random-admin-token
AUTOFILL_TOKEN_SECRET=your-long-random-autofill-token-secret
CRON_SECRET=your-secure-random-cron-secret

# Client ID verification (comma-separated list for demo)
VALID_CLIENT_IDS=client123,client456,testclient789

# Airtable API (for auto-fill feature on Update submissions)
AIRTABLE_API_KEY=your-airtable-api-key
NEXT_PUBLIC_UPDATE_TOGGLES_ENABLED=false
NEXT_PUBLIC_AUTOFILL_UPDATE_ENABLED=false

# Cloudflare D1 database (your own Cloudflare account, accessed over HTTP)
# Token needs the "D1 Edit" permission scoped to the database.
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_D1_DATABASE_ID=your-d1-database-uuid
CF_API_TOKEN=your-cloudflare-api-token

# Cloudflare R2 storage (S3-compatible API)
# CF_R2_ACCOUNT_ID can be omitted if it matches CF_ACCOUNT_ID.
CF_R2_ACCOUNT_ID=your-cloudflare-account-id
CF_R2_BUCKET=your-r2-bucket-name
CF_R2_ACCESS_KEY_ID=your-r2-access-key-id
CF_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Public URL where the app serves uploaded files via /api/uploads/[...key].
FORM_UPLOADS_PUBLIC_URL=https://webflow-app-form.webflow.io/app-form/api/uploads

# Optional: Webflow API keys if needed for verification
WEBFLOW_API_TOKEN=your-webflow-api-token
WEBFLOW_SITE_ID=your-webflow-site-id

# ---------------------------------------------------------------------------
# Sentry (optional). Fully opt-in: when these are unset, Sentry is inactive
# and the app runs normally.
# ---------------------------------------------------------------------------
# Same DSN for client and server — Sentry distinguishes via separate projects
# if you prefer, but a single browser-exposed DSN is fine for a form app.
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ENVIRONMENT=production
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
#
# Only set these in CI / the Webflow Cloud build env. They upload source maps
# so stack traces in Sentry are un-minified. Safe to leave unset locally.
# SENTRY_ORG=<your-sentry-org-slug>
# SENTRY_PROJECT=<your-sentry-project-slug>
# SENTRY_AUTH_TOKEN=<auth-token-with-project:releases-and-project:read>   # secret
