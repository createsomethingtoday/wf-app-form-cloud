# Copy this to .env.local and fill in your values

# Webhook configuration
WEBHOOK_URL=https://hooks.airtable.com/workflows/v1/genericWebhook/your-app-id/your-webhook-id/your-trigger-id
WEBHOOK_TOKEN=your-webhook-authentication-token

# Admin API protection for internal submission endpoints
ADMIN_API_TOKEN=your-long-random-admin-token
AUTOFILL_TOKEN_SECRET=your-long-random-autofill-token-secret
CRON_SECRET=your-secure-random-cron-secret

# Client ID verification (comma-separated list for demo)
VALID_CLIENT_IDS=client123,client456,testclient789

# Airtable API (for auto-fill feature on Update submissions)
AIRTABLE_API_KEY=your-airtable-api-key
NEXT_PUBLIC_UPDATE_TOGGLES_ENABLED=false
NEXT_PUBLIC_AUTOFILL_UPDATE_ENABLED=false

# Required when using the FORM_UPLOADS R2 binding
FORM_UPLOADS_PUBLIC_URL=https://pub-your-bucket-id.r2.dev

# Optional: Webflow API keys if needed for verification
WEBFLOW_API_TOKEN=your-webflow-api-token
WEBFLOW_SITE_ID=your-webflow-site-id
