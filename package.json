{
  "name": "webflow-form-app",
  "version": "1.0.0",
  "description": "External marketplace app submission form for Webflow",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "backfill:webflow-cloud": "node ./scripts/backfill-webflow-cloud.mjs",
    "test:r2": "node ./scripts/test-r2.mjs",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.49.0",
    "@vercel/analytics": "^1.5.0",
    "aws4fetch": "^1.0.20",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.563.0",
    "next": "^15.0.0",
    "quill": "^2.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.8.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^8.0.0",
    "eslint-config-next": "^15.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.4",
    "wrangler": "^4.74.0"
  }
}
